# Mobile runtime environment label: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# Base URL of your Next.js backend.
# iOS simulator can use localhost.
# Android emulator usually needs http://10.0.2.2:3000.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Supabase public credentials (same project as web app).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Telemetry controls
# Empty endpoint means telemetry logs locally only (non-production).
EXPO_PUBLIC_TELEMETRY_ENABLED=true
EXPO_PUBLIC_MOBILE_TELEMETRY_ENDPOINT=
EXPO_PUBLIC_TELEMETRY_ERROR_SAMPLE_RATE=1
EXPO_PUBLIC_TELEMETRY_PERF_SAMPLE_RATE=0.3
