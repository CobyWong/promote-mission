{
  "name": "promote-mission",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "check:env": "node scripts/check-env.mjs",
    "verify:staging": "node scripts/verify-staging.mjs",
    "verify:mobile:smoke": "node scripts/mobile-smoke.mjs",
    "alerts:funnel": "node scripts/check-funnel-alerts.mjs",
    "funnel:baseline": "node scripts/funnel-baseline-report.mjs",
    "release:gate:staging": "node scripts/release-gate-staging.mjs",
    "release:gate:production": "node scripts/release-gate-production.mjs",
    "test": "vitest run",
    "test:e2e:web": "vitest run e2e/web-flow.smoke.test.ts",
    "test:e2e:web:strict": "E2E_STRICT_REDEEM=1 vitest run e2e/web-flow.smoke.test.ts",
    "test:watch": "vitest",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:ios": "npm --prefix apps/mobile run ios",
    "mobile:android": "npm --prefix apps/mobile run android",
    "mobile:web": "npm --prefix apps/mobile run web"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "next": "^16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
